# copy to .env and fill in
# never commit .env

# Hedera account (required)
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=mainnet

# LLM provider — at least one required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Override the default model (optional; defaults to claude-sonnet-4-6 when Anthropic key is set)
# AGENT_MODEL=claude-sonnet-4-6

# HOL Standards SDK — required for `npm run register` (HCS-10 bounty requirement)
HOL_API_KEY=

# Web server port (optional, defaults to 3000)
PORT=3000

# Automatic position unwind (optional)
# Set to true to auto-unwind when health factor drops below 1.5 (DANGER zone)
MONITOR_AUTO_UNWIND=false
MONITOR_STATE_PATH=.health-monitor-state.json
