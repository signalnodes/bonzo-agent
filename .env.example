# copy to .env and fill in
# never commit .env

# Hedera account (required)
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=mainnet

# LLM provider — at least one required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# HOL Standards SDK — required for `npm run register` (HCS-10 bounty requirement)
HOL_API_KEY=

# Web server port (optional, defaults to 3000)
PORT=3000

# Health factor monitor (optional, used by `npm run monitor:health`)
# Set MONITOR_AUTO_UNWIND=true to enable automatic position unwind when HF < 1.3
MONITOR_AUTO_UNWIND=false
MONITOR_STATE_PATH=.health-monitor-state.json
